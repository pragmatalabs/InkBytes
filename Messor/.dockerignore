# https://docs.docker.com/engine/reference/builder/#dockerignore-file

**/.DS_Store
**/__pycache__
**/.venv
**/.classpath
**/.dockerignore
**/.git
**/.gitignore
**/.project
**/.settings
**/.toolstarget
**/.vs
**/.vscode
**/*.*proj.user
**/*.dbmdl
**/*.jfm
**/bin
**/charts
**/docker-compose*
**/compose*
**/Dockerfile*
**/node_modules
**/npm-debug.log
**/obj
**/secrets.dev.yaml
**/values.dev.yaml
LICENSE
README.md
**/docker/*.*
.claude
.forget
.vscode
.gitignore
.gitlab-ci.yml
CLAUDE.md
.forget/env.example.yaml

# Monorepo Docker baseline (explicitly include build files)
!infra/docker/docker-compose.yml
!infra/docker/.env.example
!infra/docker/platform/php-fpm.Dockerfile
!infra/docker/platform/node.Dockerfile
!infra/docker/platform/nginx/default.conf
!infra/docker/scraper.Dockerfile
