APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Shared Postgres+pgvector (same instance as Curator). Laravel is isolated
# in the `backoffice` schema (search_path=backoffice,public); see ADR-0003.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=inkbytes
DB_USERNAME=inkbytes
DB_PASSWORD=inkbytes

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Curator moderation commands (Phase 2.3) — published via RabbitMQ management HTTP API.
RABBITMQ_MANAGEMENT_URL=http://localhost:15672
RABBITMQ_USER=messor
RABBITMQ_PASSWORD=messor
RABBITMQ_VHOST=/
CURATOR_COMMANDS_EXCHANGE=curator.commands

# Unified health dashboard (B6) — service base URLs probed read-only with a
# short timeout. RabbitMQ reachability reuses the RABBITMQ_* creds above
# (server-side only; never sent to the browser).
CURATOR_URL=http://localhost:8060
MESSOR_URL=http://localhost:8050

# Scraping trigger (Backoffice "▶ Iniciar Scraping") → ScrapingJobController@trigger
# → RunScrapingWorker (queued on the `scraping` queue). Must be set or trigger 422s
# with "SCRAPING_COMMAND is not configured."
#
# With SCRAPING_REMOTE_HOST empty the worker runs the command locally via `bash -lc`.
# Use the Messor one-shot harvester with --no-api so it does NOT bind :8050 (already
# owned by the running messor-api); pipe stdin from /dev/null for a non-TTY clean exit.
# Use absolute paths. Example (adjust the repo path / --limit to taste):
#
# SCRAPING_COMMAND="cd /absolute/path/to/InkBytes/Messor/apps/scraper && .venv/bin/python main.py env.local.yaml --scrape=--limit=2 --no-api < /dev/null"
#
# Apple Silicon note: if your local php/queue worker is an x86_64 (Rosetta) build,
# the worker's child shell inherits the x86_64 personality and the arm64 Messor venv
# fails to load (pydantic .so "incompatible architecture"). Prefix the interpreter
# with `arch -arm64` to pin the native interpreter:
#
# SCRAPING_COMMAND="cd /absolute/path/to/InkBytes/Messor/apps/scraper && arch -arm64 .venv/bin/python main.py env.local.yaml --scrape=--limit=2 --no-api < /dev/null"
#
# NOTE: the Backoffice needs a worker on the `scraping` queue for triggered jobs to run:
#   php artisan queue:work --queue=scraping --timeout=0
SCRAPING_COMMAND=

# Optional: run the harvester over SSH on a remote host instead of locally.
# When SCRAPING_REMOTE_HOST is set the worker tees output to SCRAPING_LOG_DIR remotely.
# SCRAPING_REMOTE_HOST=
# SCRAPING_LOG_DIR=/tmp/scraping
# SCRAPING_PROCESS_TIMEOUT=
