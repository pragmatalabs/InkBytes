# InkBytes — production environment template
# Copy to infra/.env, fill all CHANGE_ME values. NEVER commit infra/.env.
#
#   cp infra/.env.production.example infra/.env

# ── Domains ──────────────────────────────────────────────────────────────────
READER_DOMAIN=inkbytes.org
ADMIN_DOMAIN=admin.inkbytes.org

# ── Registry images (set by deploy.yml; override here for manual deploys) ────
DO_REGISTRY=pragmata
READER_IMAGE=registry.digitalocean.com/pragmata/inkbytes-reader:latest
BACKOFFICE_IMAGE=registry.digitalocean.com/pragmata/inkbytes-backoffice:latest
CURATOR_IMAGE=registry.digitalocean.com/pragmata/inkbytes-curator:latest
MESSOR_IMAGE=registry.digitalocean.com/pragmata/inkbytes-messor:latest

# ── Laravel Backoffice ───────────────────────────────────────────────────────
# Generate: php artisan key:generate --show
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate_--show
INKBYTES_DEMO_PASSWORD=CHANGE_ME_READER_ACCESS_PASSWORD

# ── Database (Postgres + pgvector) ───────────────────────────────────────────
POSTGRES_DB=inkbytes
POSTGRES_USER=inkbytes
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=inkbytes
RABBITMQ_PASS=CHANGE_ME_STRONG_RABBITMQ_PASSWORD

# ── MinIO (internal object store) ────────────────────────────────────────────
MINIO_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET=CHANGE_ME_MINIO_SECRET_KEY

# ── DigitalOcean Spaces (production article archival) ────────────────────────
# Used by Messor for long-term article storage. Different from MinIO.
DO_SPACES_KEY=CHANGE_ME_DO_SPACES_KEY
DO_SPACES_SECRET=CHANGE_ME_DO_SPACES_SECRET
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=inkbytes-articles

# ── LLM API keys (Curator reads these from env OR from Backoffice DB) ────────
ANTHROPIC_API_KEY=CHANGE_ME_sk-ant-...
OPENAI_API_KEY=CHANGE_ME_sk-...
DEEPSEEK_API_KEY=CHANGE_ME_sk-...

# ── Embeddings (default: local Ollama bge-m3) ────────────────────────────────
# Switch to openai if Ollama is unavailable:
#   EMBEDDINGS_PROVIDER=openai
#   EMBEDDINGS_BASE_URL=   (blank = api.openai.com)
#   EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_BASE_URL=http://inkbytes-ollama:11434/v1
EMBEDDINGS_MODEL=bge-m3
