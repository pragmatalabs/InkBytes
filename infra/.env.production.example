# InkBytes — production environment template
# Copy to infra/.env, fill all CHANGE_ME values. NEVER commit infra/.env.
#
#   cp infra/.env.production.example infra/.env

# ── Domains ──────────────────────────────────────────────────────────────────
# Temporary: *.galvanic.cloud while inkbytes.news propagates
READER_DOMAIN=inkbytes.galvanic.cloud
ADMIN_DOMAIN=admin.inkbytes.galvanic.cloud

# ── Registry images (GitHub Container Registry — free, no vendor lock-in) ────
# Set by deploy.yml on every push; override here for manual server builds.
# Format: ghcr.io/<github-org>/<service>:<tag>
READER_IMAGE=ghcr.io/pragmatalabs/inkbytes-reader:latest
BACKOFFICE_IMAGE=ghcr.io/pragmatalabs/inkbytes-backoffice:latest
CURATOR_IMAGE=ghcr.io/pragmatalabs/inkbytes-curator:latest
MESSOR_IMAGE=ghcr.io/pragmatalabs/inkbytes-messor:latest

# ── Laravel Backoffice ───────────────────────────────────────────────────────
# Generate: php artisan key:generate --show
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate_--show
# INKBYTES_DEMO_PASSWORD=   # blank (or unset) = open public access; set a value to require password

# Scraping trigger — POST to Messor's internal trigger endpoint.
# The queue worker (supervisord queue-worker) picks up the job and calls this.
# Messor and Backoffice share inkbytes-internal Docker network.
SCRAPING_COMMAND=curl -sf -X POST http://inkbytes-messor:8050/api/scrape/trigger -H "Content-Type: application/json" -d "{}" > /dev/null 2>&1 || true

# ── Database (Postgres + pgvector) ───────────────────────────────────────────
POSTGRES_DB=inkbytes
POSTGRES_USER=inkbytes
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=inkbytes
RABBITMQ_PASS=CHANGE_ME_STRONG_RABBITMQ_PASSWORD

# ── MinIO (internal object store) ────────────────────────────────────────────
MINIO_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET=CHANGE_ME_MINIO_SECRET_KEY

# ── DigitalOcean Spaces (S3) ──────────────────────────────────────────────────
# Used for article archival AND editorial audio (ADR-0011 — the Piper MP3s land at
# {ENDPOINT}/{BUCKET}/audio/outlook/...). Leave KEY/SECRET blank to skip uploads
# (editorial TTS then no-ops). Can point at MinIO for testing:
#   DO_SPACES_ENDPOINT=http://inkbytes-minio:9000
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=inkbytes-prod
DO_SPACES_PUBLIC_BASE=          # optional CDN base; blank → {ENDPOINT}/{BUCKET}

# ── Editorial TTS (ADR-0011 — self-hosted Piper, $0/char) ─────────────────────
# Voices are baked into the editorial image; override only to a voice also present
# there. Set EDITORIAL_TTS_ENABLED=false to skip audio entirely.
EDITORIAL_TTS_ENABLED=true
EDITORIAL_TTS_VOICE_EN=          # blank → en_US-ryan-high (image default)
EDITORIAL_TTS_VOICE_ES=          # blank → es_MX-ald-medium (image default)

# ── LLM API keys (Curator reads these from env OR from Backoffice DB) ────────
ANTHROPIC_API_KEY=CHANGE_ME_sk-ant-...
OPENAI_API_KEY=CHANGE_ME_sk-...
DEEPSEEK_API_KEY=CHANGE_ME_sk-...

# ── Embeddings — Ollama runs locally in the inkbytes-ollama container ─────────
# inkbytes-ollama is included in docker-compose.prod.yml (own container, not shared).
# Pull bge-m3 on first deploy:  docker exec inkbytes-ollama ollama pull bge-m3
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_BASE_URL=http://inkbytes-ollama:11434/v1
EMBEDDINGS_MODEL=bge-m3
