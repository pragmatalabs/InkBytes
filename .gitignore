# InkBytes monorepo (GitHub: pragmatalabs/InkBytes)
# Default-ignore everything at the root, then re-include the tracked dirs.
# Unifying into GitHub: the former GitLab modules (database, common, models)
# are now part of this monorepo. Remove their nested .git dirs before adding.
# Entopics, Unitas, Synochi, hermes and the rest stay parked under Trashx/.
/*
!.gitignore
!CLAUDE.md
!Messor/
!Curator/
!Reader/
!Editorial/
!orchestrator/
!docs/
!infra/
!.github/
!Makefile
!scripts/
!database/
!common/
!models/
# !src/   <- legacy duplicate of Messor/packages/inkbytes (+ DocTrainer); enable only if you want it tracked

# ── Build / dependency / runtime junk (applies inside the tracked dirs) ──
node_modules/
.next/
.turbo/
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
*.tsbuildinfo

# ── Logs, data, runtime artifacts ──
*.log
logs/
*.sqlite3
data/scrapes/
data/history/
data/rabbit/
data/local/

# ── Secrets / local config (never commit) ──
.env
.env.*
!.env.example
!.env.production.example
infra/.env         # production secrets — never commit
env.local.yaml
*.local.yaml
.secrets.env

# ── OS / editor ──
.DS_Store
.idea/
.vscode/
.claude/settings.local.json
